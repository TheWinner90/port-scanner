import socket

target = input("Entrez l'adresse IP : ")

print(f"Scan de {target} en cours...\n")

for port in range(1, 1025):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(0.5)

    result = s.connect_ex((target, port))
    
    if result == 0:
        print(f"Port {port} est OUVERT")

    s.close()

print("\nScan terminé.")
